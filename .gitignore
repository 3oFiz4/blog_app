
# ==============================================================================
# 📦 Dependencies (Never commit these, download fresh via npm install)
# ==============================================================================
node_modules/
**/node_modules/
package-lock.json
**/package-lock.json

# ==============================================================================
# 🔑 Security / Credentials (CRITICAL: Keeps passwords & API keys secret)
# ==============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env*.local

# ==============================================================================
# 🏗️ Production Builds (Compiled files generated during deployment)
# ==============================================================================
# React build production folder
dist/
build/
**/dist/
**/build/

# Next.js / alternative frontend frameworks if used
.next/
out/

# Vite caches
.vite/

# ==============================================================================
# 🩺 Logs and Diagnostics
# ==============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

